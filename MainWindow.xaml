<Window
    x:Class="WCtrlDcsBiosBridge.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="using:WCtrlDcsBiosBridge.UI"
    xmlns:conv="using:WCtrlDcsBiosBridge.UI.Converters"
    xmlns:config="using:WCtrlDcsBiosBridge.Config">

    <Grid x:Name="WindowRoot" Background="{StaticResource WindowBackground}">
    <Grid x:Name="RootGrid" Margin="20">
        <Grid.Resources>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: title left, language + theme toggles right -->
        <Grid Grid.Row="0" Margin="0,0,0,14" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Winctrl DCS-BIOS Bridge"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <Button x:Name="LanguageToggleButton"
                    Grid.Column="1"
                    Width="32" Height="32"
                    Padding="0"
                    Margin="0,0,4,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="LanguageToggle_Click">
                <TextBlock x:Name="LanguageIcon"
                           Text="🌐"
                           FontSize="13"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>
            <Button x:Name="ThemeToggleButton"
                    Grid.Column="2"
                    Width="32" Height="32"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="ThemeToggle_Click">
                <TextBlock x:Name="ThemeIcon"
                           Text="◑"
                           FontSize="15"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>
        </Grid>

        <!-- Tab Control -->
        <Pivot x:Name="MainPivot" Grid.Row="1">

            <!-- ══ Dashboard ══ -->
            <PivotItem x:Name="DashboardPivotItem" x:Uid="DashboardPivotItem" Header="Dashboard">
                <Grid Margin="14,12,14,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Bridge status card + Start Bridge button -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14,10"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="BridgeStatusDot"
                                         Width="10" Height="10"
                                         Fill="#888888"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock x:Name="BridgeStatusLabel"
                                               x:Uid="Status_BridgeStopped"
                                               Text="Bridge stopped"
                                               FontWeight="SemiBold"
                                               FontSize="13"/>
                                    <TextBlock x:Name="BridgeStatusSub"
                                               x:Uid="Status_AircraftAutoDetected"
                                               Text="Aircraft is detected automatically when DCS is running"
                                               Foreground="{StaticResource SubtleTextForeground}"
                                               FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <Button x:Name="StartButton"
                                    x:Uid="StartButton_Start"
                                    Grid.Column="1"
                                    Content="Start Bridge"
                                    MinWidth="110"
                                    VerticalAlignment="Center"
                                    Click="StartButton_Click"/>
                        </Grid>
                    </Border>

                    <!-- Description -->
                    <TextBlock Grid.Row="1"
                               x:Name="DashboardDescriptionText"
                               x:Uid="DashboardDescriptionText"
                               Text="Start the bridge, then load into a supported aircraft in DCS World. The CDU or FCU/EFIS display will sync automatically."
                               TextWrapping="Wrap"
                               Foreground="{StaticResource SubtleTextForeground}"
                               FontSize="12"
                               Margin="0,0,0,12"/>

                    <!-- Connected devices -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,4">
                        <TextBlock x:Name="ConnectedDevicesHeader" x:Uid="ConnectedDevicesHeader" Text="CONNECTED DEVICES"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SubtleTextForeground}"
                                   Margin="0,0,0,6"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="DeviceListPanel" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- Status bar -->
                    <ui:StatusBarControl x:Name="StatusControl"
                                         Grid.Row="4"
                                         Margin="0,0,0,0"
                                         HorizontalAlignment="Left"/>

                    <!-- Update Notification Banner -->
                    <Border x:Name="UpdateBanner"
                            Grid.Row="5"
                            Background="{StaticResource UpdateBannerBackground}"
                            BorderBrush="{StaticResource UpdateBannerBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="10,7"
                            Margin="0,8,0,0"
                            Visibility="{Binding IsUpdateVisible, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding UpdateMessage}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Foreground="{StaticResource UpdateBannerForeground}"/>
                            <Button Grid.Column="1" x:Name="OpenReleaseButtonControl" x:Uid="OpenReleaseButtonControl" Content="Open release"
                                    Click="OpenUpdateLink_Click"
                                    Margin="6,0,0,0"
                                    Padding="10,3"
                                    MinWidth="100"/>
                            <Button Grid.Column="2" x:Name="DismissButtonControl" x:Uid="DismissButtonControl" Content="Dismiss"
                                    Click="DismissUpdate_Click"
                                    Margin="6,0,0,0"
                                    Padding="10,3"
                                    MinWidth="80"/>
                        </Grid>
                    </Border>
                </Grid>
            </PivotItem>

            <!-- ══ Configuration ══ -->
            <PivotItem x:Name="ConfigurationPivotItem" x:Uid="ConfigurationPivotItem" Header="Configuration">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <ui:OptionsPanel x:Name="OptionsPanel"
                                         Margin="14,12"/>
                    </ScrollViewer>

                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="14,10">
                        <Button x:Name="ConfigButton"
                                x:Uid="ConfigButtonControl"
                                Content="Edit DCS-BIOS Configuration"
                                MinWidth="210"
                                HorizontalAlignment="Left"
                                Click="ConfigButton_Click"
                                IsEnabled="{Binding CanEdit}"/>
                    </Border>
                </Grid>
            </PivotItem>

            <!-- ══ Help ══ -->
            <PivotItem x:Name="HelpPivotItem" x:Uid="HelpPivotItem" Header="Help">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,12">

                        <TextBlock x:Name="QuickStartHeader" x:Uid="QuickStartHeader" Text="Quick start" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11"
                                    BorderThickness="1" BorderBrush="{StaticResource StepBorderBrush}"
                                    Margin="0,0,8,0" VerticalAlignment="Top">
                                <TextBlock Text="1" FontSize="10" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="{StaticResource StepForeground}"/>
                            </Border>
                            <TextBlock Grid.Column="1" x:Name="HelpStep1Text" x:Uid="HelpStep1Text" Text="Connect your Winwing device(s) via USB"
                                       TextWrapping="Wrap" FontSize="12"
                                       Foreground="{StaticResource HelpTextForeground}" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11"
                                    BorderThickness="1" BorderBrush="{StaticResource StepBorderBrush}"
                                    Margin="0,0,8,0" VerticalAlignment="Top">
                                <TextBlock Text="2" FontSize="10" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="{StaticResource StepForeground}"/>
                            </Border>
                            <TextBlock Grid.Column="1" x:Name="HelpStep2Text" x:Uid="HelpStep2Text" Text="Click Start Bridge on the Dashboard tab. Connected devices will be listed."
                                       TextWrapping="Wrap" FontSize="12"
                                       Foreground="{StaticResource HelpTextForeground}" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11"
                                    BorderThickness="1" BorderBrush="{StaticResource StepBorderBrush}"
                                    Margin="0,0,8,0" VerticalAlignment="Top">
                                <TextBlock Text="3" FontSize="10" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="{StaticResource StepForeground}"/>
                            </Border>
                            <TextBlock Grid.Column="1" x:Name="HelpStep3Text" x:Uid="HelpStep3Text" Text="Load into a mission in DCS World. The aircraft module is detected automatically — no manual selection needed."
                                       TextWrapping="Wrap" FontSize="12"
                                       Foreground="{StaticResource HelpTextForeground}" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11"
                                    BorderThickness="1" BorderBrush="{StaticResource StepBorderBrush}"
                                    Margin="0,0,8,0" VerticalAlignment="Top">
                                <TextBlock Text="4" FontSize="10" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="{StaticResource StepForeground}"/>
                            </Border>
                            <TextBlock Grid.Column="1" x:Name="HelpStep4Text" x:Uid="HelpStep4Text" Text="Your CDU or FCU/EFIS will sync with the in-game cockpit. The Dashboard tab shows live status."
                                       TextWrapping="Wrap" FontSize="12"
                                       Foreground="{StaticResource HelpTextForeground}" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource CardBorderBrush}" Margin="0,12"/>

                        <TextBlock FontSize="12" TextWrapping="Wrap">
                            <Hyperlink x:Name="DocsLink" Click="DocsLink_Click"><Run x:Name="SupportedAircraftLink" x:Uid="SupportedAircraftLink">Supported aircraft</Run></Hyperlink>
                        </TextBlock>

                        <Border Height="1" Background="{StaticResource CardBorderBrush}" Margin="0,12"/>

                        <TextBlock x:Name="TroubleshootingHeader" x:Uid="TroubleshootingHeader" Text="Troubleshooting" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="?" FontSize="11"
                                       Foreground="{StaticResource StepForeground}" VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1" FontSize="12" Foreground="{StaticResource HelpTextForeground}" TextWrapping="Wrap">
                                <Run x:Name="Trouble1Strong" x:Uid="Trouble1Strong" FontWeight="SemiBold">Device not shown in Dashboard:</Run><Run x:Name="Trouble1Rest" x:Uid="Trouble1Rest"> unplug and replug the USB cable, then restart the app.</Run>
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="?" FontSize="11"
                                       Foreground="{StaticResource StepForeground}" VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1" FontSize="12" Foreground="{StaticResource HelpTextForeground}" TextWrapping="Wrap">
                                <Run x:Name="Trouble2Strong" x:Uid="Trouble2Strong" FontWeight="SemiBold">CDU screen blank in-game:</Run><Run x:Name="Trouble2Rest" x:Uid="Trouble2Rest"> confirm the DCS-BIOS export script is installed and DCS World is running.</Run>
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="?" FontSize="11"
                                       Foreground="{StaticResource StepForeground}" VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1" FontSize="12" Foreground="{StaticResource HelpTextForeground}" TextWrapping="Wrap">
                                <Run x:Name="Trouble3Strong" x:Uid="Trouble3Strong" FontWeight="SemiBold">Wrong aircraft data:</Run><Run x:Name="Trouble3Rest" x:Uid="Trouble3Rest"> ensure DCS-BIOS is up to date and the correct module is loaded in DCS.</Run>
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="?" FontSize="11"
                                       Foreground="{StaticResource StepForeground}" VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1" FontSize="12" Foreground="{StaticResource HelpTextForeground}" TextWrapping="Wrap">
                                <Run x:Name="Trouble4Strong" x:Uid="Trouble4Strong" FontWeight="SemiBold">SimApp Pro lighting conflict:</Run><Run x:Name="Trouble4Mid" x:Uid="Trouble4Mid"> enable </Run><Run x:Name="Trouble4Italic" x:Uid="Trouble4Italic" FontStyle="Italic">Disable Lighting Management</Run><Run x:Name="Trouble4End" x:Uid="Trouble4End"> in the Configuration tab.</Run>
                            </TextBlock>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

        </Pivot>
    </Grid>

    <!-- Config overlay: an in-window panel (not a secondary Window) — see ConfigPanel.xaml.cs
         for why secondary windows are avoided here. -->
    <Grid x:Name="ConfigOverlay" Visibility="Collapsed" Background="#AA000000">
        <Border MaxWidth="560" MaxHeight="540"
                Background="{StaticResource WindowBackground}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <config:ConfigPanel x:Name="ConfigPanelControl"/>
        </Border>
    </Grid>
    </Grid>
</Window>
