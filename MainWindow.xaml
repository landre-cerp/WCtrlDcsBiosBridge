<Window x:Class="WCtrlDcsBiosBridge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:WCtrlDcsBiosBridge.UI"
        Title="WctrlDcsBiosBridge"
        Height="620"
        MinHeight="560"
        Width="640"
        MinWidth="580"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}"
        DataContext="{Binding RelativeSource={RelativeSource Self}}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: title left, theme toggle right -->
        <DockPanel Grid.Row="0" Margin="0,0,0,14" VerticalAlignment="Center">
            <Button x:Name="ThemeToggleButton"
                    DockPanel.Dock="Right"
                    Width="32" Height="32"
                    Style="{StaticResource IconButton}"
                    Click="ThemeToggle_Click">
                <TextBlock x:Name="ThemeIcon"
                           Text="◑"
                           FontSize="15"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>
            <TextBlock Text="Winctrl DCS-BIOS Bridge"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Tab Control -->
        <TabControl x:Name="MainTabControl" Grid.Row="1">

            <!-- ══ Dashboard ══ -->
            <TabItem Header="Dashboard">
                <Grid Margin="14,12,14,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Bridge status card + Start Bridge button -->
                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14,10"
                            Margin="0,0,0,10">
                        <DockPanel>
                            <Button x:Name="StartButton"
                                    DockPanel.Dock="Right"
                                    Content="Start Bridge"
                                    Width="110" Height="28"
                                    VerticalAlignment="Center"
                                    Click="StartButton_Click"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="BridgeStatusDot"
                                         Width="10" Height="10"
                                         Fill="#888888"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock x:Name="BridgeStatusLabel"
                                               Text="Bridge stopped"
                                               FontWeight="SemiBold"
                                               FontSize="13"/>
                                    <TextBlock x:Name="BridgeStatusSub"
                                               Text="Aircraft is detected automatically when DCS is running"
                                               Foreground="{DynamicResource SubtleTextForeground}"
                                               FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Description -->
                    <TextBlock Grid.Row="1"
                               Text="Start the bridge, then load into a supported aircraft in DCS World. The CDU or FCU/EFIS display will sync automatically."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SubtleTextForeground}"
                               FontSize="12"
                               Margin="0,0,0,12"/>

                    <!-- Connected devices -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,4">
                        <TextBlock Text="CONNECTED DEVICES"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SubtleTextForeground}"
                                   Margin="0,0,0,6"/>
                        <WrapPanel x:Name="DeviceListPanel"/>
                    </StackPanel>

                    <!-- Status bar -->
                    <ui:StatusBarControl x:Name="StatusControl"
                                         Grid.Row="4"
                                         Margin="0,0,0,0"
                                         HorizontalAlignment="Left"/>

                    <!-- Update Notification Banner -->
                    <Border Grid.Row="5"
                            Background="{DynamicResource UpdateBannerBackground}"
                            BorderBrush="{DynamicResource UpdateBannerBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="10,7"
                            Margin="0,8,0,0"
                            Visibility="{Binding IsUpdateVisible, Converter={StaticResource BoolToVisibility}}">
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="{Binding UpdateMessage}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Foreground="{DynamicResource UpdateBannerForeground}"/>
                            <Button Content="Open release"
                                    Click="OpenUpdateLink_Click"
                                    DockPanel.Dock="Right"
                                    Margin="6,0,0,0"
                                    Padding="10,3"
                                    MinWidth="100"/>
                            <Button Content="Dismiss"
                                    Click="DismissUpdate_Click"
                                    DockPanel.Dock="Right"
                                    Padding="10,3"
                                    MinWidth="80"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══ Configuration ══ -->
            <TabItem Header="Configuration" x:Name="ConfigurationTab">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <ui:OptionsPanel x:Name="OptionsPanel"
                                         Margin="14,12"/>
                    </ScrollViewer>

                    <Border Grid.Row="1"
                            BorderBrush="{DynamicResource CardBorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="14,10">
                        <Button x:Name="ConfigButton"
                                Content="Edit DCS-BIOS Configuration"
                                Width="210" Height="28"
                                HorizontalAlignment="Left"
                                Click="ConfigButton_Click"
                                IsEnabled="{Binding CanEdit, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </Border>
                </Grid>
            </TabItem>


<!-- ══ Help ══ -->
            <TabItem Header="Help">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,12">

                        <TextBlock Text="Quick start" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <DockPanel Margin="0,3">
                            <Border DockPanel.Dock="Left" Width="22" Height="22" CornerRadius="11"
                                    BorderThickness="1" BorderBrush="{DynamicResource StepBorderBrush}"
                                    Margin="0,0,8,0" VerticalAlignment="Top">
                                <TextBlock Text="1" FontSize="10" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="{DynamicResource StepForeground}"/>
                            </Border>
                            <TextBlock Text="Connect your Winwing device(s) via USB. They appear in the Dashboard once detected."
                                       TextWrapping="Wrap" FontSize="12"
                                       Foreground="{DynamicResource HelpTextForeground}" VerticalAlignment="Center"/>
                        </DockPanel>

                        <DockPanel Margin="0,3">
                            <Border DockPanel.Dock="Left" Width="22" Height="22" CornerRadius="11"
                                    BorderThickness="1" BorderBrush="{DynamicResource StepBorderBrush}"
                                    Margin="0,0,8,0" VerticalAlignment="Top">
                                <TextBlock Text="2" FontSize="10" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="{DynamicResource StepForeground}"/>
                            </Border>
                            <TextBlock Text="Click Start Bridge on the Dashboard tab."
                                       TextWrapping="Wrap" FontSize="12"
                                       Foreground="{DynamicResource HelpTextForeground}" VerticalAlignment="Center"/>
                        </DockPanel>

                        <DockPanel Margin="0,3">
                            <Border DockPanel.Dock="Left" Width="22" Height="22" CornerRadius="11"
                                    BorderThickness="1" BorderBrush="{DynamicResource StepBorderBrush}"
                                    Margin="0,0,8,0" VerticalAlignment="Top">
                                <TextBlock Text="3" FontSize="10" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="{DynamicResource StepForeground}"/>
                            </Border>
                            <TextBlock Text="Load into a mission in DCS World. The aircraft module is detected automatically — no manual selection needed."
                                       TextWrapping="Wrap" FontSize="12"
                                       Foreground="{DynamicResource HelpTextForeground}" VerticalAlignment="Center"/>
                        </DockPanel>

                        <DockPanel Margin="0,3">
                            <Border DockPanel.Dock="Left" Width="22" Height="22" CornerRadius="11"
                                    BorderThickness="1" BorderBrush="{DynamicResource StepBorderBrush}"
                                    Margin="0,0,8,0" VerticalAlignment="Top">
                                <TextBlock Text="4" FontSize="10" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="{DynamicResource StepForeground}"/>
                            </Border>
                            <TextBlock Text="Your CDU or FCU/EFIS will sync with the in-game cockpit. The Dashboard tab shows live status."
                                       TextWrapping="Wrap" FontSize="12"
                                       Foreground="{DynamicResource HelpTextForeground}" VerticalAlignment="Center"/>
                        </DockPanel>

                        <Separator Margin="0,12"/>

                        <TextBlock Text="DCS-BIOS network" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Border Background="{DynamicResource InfoBoxBackground}"
                                BorderBrush="{DynamicResource InfoBoxBorderBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="10,7">
                            <TextBlock FontSize="12" Foreground="{DynamicResource InfoBoxForeground}" TextWrapping="Wrap">
                                Default receive: <Run FontWeight="SemiBold">239.255.50.10:5010</Run>&#160; · &#160;Default send: <Run FontWeight="SemiBold">127.0.0.1:7778</Run><LineBreak/>
                                Only change these if your DCS-BIOS uses non-default ports — use <Run FontStyle="Italic">Edit DCS-BIOS Configuration</Run> in the Configuration tab.
                            </TextBlock>
                        </Border>

                        <Separator Margin="0,12"/>

                        <TextBlock Text="Supported aircraft" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Text="A-10C · AH-64D · F/A-18C · F-15E · F-16C · CH-47F (pilot &amp; copilot) · M-2000C"
                                   FontSize="12" Foreground="{DynamicResource HelpTextForeground}" TextWrapping="Wrap"/>

                        <Separator Margin="0,12"/>

                        <TextBlock Text="Troubleshooting" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <DockPanel Margin="0,3">
                            <TextBlock DockPanel.Dock="Left" Text="?" FontSize="11"
                                       Foreground="{DynamicResource StepForeground}" Width="22" VerticalAlignment="Top"/>
                            <TextBlock FontSize="12" Foreground="{DynamicResource HelpTextForeground}" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold">Device not shown in Dashboard:</Run> unplug and replug the USB cable, then restart the app.
                            </TextBlock>
                        </DockPanel>

                        <DockPanel Margin="0,3">
                            <TextBlock DockPanel.Dock="Left" Text="?" FontSize="11"
                                       Foreground="{DynamicResource StepForeground}" Width="22" VerticalAlignment="Top"/>
                            <TextBlock FontSize="12" Foreground="{DynamicResource HelpTextForeground}" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold">CDU screen blank in-game:</Run> confirm the DCS-BIOS export script is installed and DCS World is running.
                            </TextBlock>
                        </DockPanel>

                        <DockPanel Margin="0,3">
                            <TextBlock DockPanel.Dock="Left" Text="?" FontSize="11"
                                       Foreground="{DynamicResource StepForeground}" Width="22" VerticalAlignment="Top"/>
                            <TextBlock FontSize="12" Foreground="{DynamicResource HelpTextForeground}" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold">Wrong aircraft data:</Run> ensure DCS-BIOS is up to date and the correct module is loaded in DCS.
                            </TextBlock>
                        </DockPanel>

                        <DockPanel Margin="0,3">
                            <TextBlock DockPanel.Dock="Left" Text="?" FontSize="11"
                                       Foreground="{DynamicResource StepForeground}" Width="22" VerticalAlignment="Top"/>
                            <TextBlock FontSize="12" Foreground="{DynamicResource HelpTextForeground}" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold">SimApp Pro lighting conflict:</Run> enable <Run FontStyle="Italic">Disable Lighting Management</Run> in the Configuration tab.
                            </TextBlock>
                        </DockPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
