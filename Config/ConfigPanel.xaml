<UserControl
    x:Class="WCtrlDcsBiosBridge.Config.ConfigPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   x:Name="ConfigPanelTitle" x:Uid="ConfigPanelTitle"
                   Text="DCS-BIOS Configuration"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,10"
                   HorizontalAlignment="Center"/>

        <!-- Configuration Panel -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="380">
            <StackPanel>

                <!-- Network Settings -->
                <TextBlock x:Name="NetworkSettingsHeader" x:Uid="NetworkSettingsHeader" Text="Network Settings" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Border BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   x:Name="ReceiveIpPortLabel" x:Uid="ReceiveIpPortLabel"
                                   Text="Receive IP:PORT"
                                   VerticalAlignment="Center"
                                   Margin="0,3"/>
                        <TextBox x:Name="ReceiveIpTextBox"
                                 Grid.Row="0" Grid.Column="1"
                                 Margin="10,3"/>
                        <TextBox x:Name="ReceivePortTextBox"
                                 Grid.Row="0" Grid.Column="2"
                                 Margin="10,3"/>
                        <TextBlock Grid.Row="0" Grid.Column="3"
                                   x:Name="MulticastLabel" x:Uid="MulticastLabel"
                                   Text="(Multicast)"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SubtleTextForeground}"
                                   FontStyle="Italic"/>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   x:Name="SendIpPortLabel" x:Uid="SendIpPortLabel"
                                   Text="Send IP:PORT"
                                   VerticalAlignment="Center"
                                   Margin="0,3"/>
                        <TextBox x:Name="SendIpTextBox"
                                 Grid.Row="1" Grid.Column="1"
                                 Margin="10,3"/>
                        <TextBox x:Name="SendPortTextBox"
                                 Grid.Row="1" Grid.Column="2"
                                 Margin="10,3"/>
                        <TextBlock Grid.Row="1" Grid.Column="3"
                                   x:Name="UsuallyLocalhostLabel" x:Uid="UsuallyLocalhostLabel"
                                   Text="(Usually localhost)"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SubtleTextForeground}"
                                   FontStyle="Italic"/>

                        <Button Grid.Row="2" Grid.Column="1"
                                x:Name="ResetToDefaultsButton"
                                x:Uid="ResetToDefaultsButtonControl"
                                Content="Reset to Defaults"
                                MinWidth="140"
                                Margin="10,8,0,0"
                                HorizontalAlignment="Left"
                                Click="ResetToDefaultsButton_Click"/>
                    </Grid>
                </Border>

                <!-- File Locations -->
                <TextBlock x:Name="FileLocationsHeader" x:Uid="FileLocationsHeader" Text="File Locations" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Border BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   x:Name="JsonLocationLabel" x:Uid="JsonLocationLabel"
                                   Text="DCS-BIOS JSON:"
                                   VerticalAlignment="Center"
                                   Margin="0,3"/>
                        <TextBox x:Name="JsonLocationTextBox"
                                 Grid.Row="0" Grid.Column="1"
                                 Margin="10,3"/>
                        <Button x:Name="BrowseButton"
                                x:Uid="BrowseButtonControl"
                                Grid.Row="0" Grid.Column="2"
                                Content="Browse..."
                                MinWidth="90"
                                Margin="5,3,0,0"
                                Click="BrowseButton_Click"/>

                        <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                   x:Name="JsonLocationHint" x:Uid="JsonLocationHint"
                                   Text="This should point to the directory containing aircraft-specific JSON files from DCS-BIOS"
                                   Foreground="{StaticResource SubtleTextForeground}"
                                   FontStyle="Italic"
                                   TextWrapping="Wrap"
                                   Margin="10,0"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Status -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="2"
                   TextWrapping="Wrap"
                   Margin="0,10,0,0"
                   Visibility="Collapsed"/>

        <!-- Control Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button x:Name="SaveButton"
                    x:Uid="SaveButtonControl"
                    Content="Save"
                    MinWidth="100"
                    Margin="0,0,10,0"
                    Click="SaveButton_Click"/>
            <Button x:Name="CancelButton"
                    x:Uid="CancelButtonControl"
                    Content="Cancel"
                    MinWidth="100"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
