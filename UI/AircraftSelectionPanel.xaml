<UserControl x:Class="WWCduDcsBiosBridge.UI.AircraftSelectionPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <GroupBox Header="Aircraft Selection" Padding="8" Margin="0,0,0,15">
        <StackPanel>
            <TextBlock Text="{Binding HeaderMessage}"
                      TextWrapping="Wrap"
                      Margin="0,0,0,8"
                      Foreground="Gray"/>

            <TextBlock Text="{Binding SelectionStatus}"
                      FontWeight="Bold"
                      Foreground="{Binding SelectionStatusColor}"
                      Margin="0,0,0,8"/>

            <ItemsControl ItemsSource="{Binding AircraftEntries}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Label}"
                                Margin="3" Padding="8,4"
                                Command="{Binding DataContext.SelectAircraftCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding DataContext.ButtonsEnabled, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </GroupBox>
</UserControl>
