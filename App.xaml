<Application
    x:Class="WCtrlDcsBiosBridge.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Declared once; ThemeManager mutates these brushes' Color in place so every
                 {StaticResource} reference across the app updates live when the theme changes
                 (WinUI3 has no DynamicResource — swapping resource dictionaries at runtime does
                 not refresh already-bound elements, but mutating a shared brush instance does). -->
            <SolidColorBrush x:Key="WindowBackground" Color="#1E1E1E"/>
            <SolidColorBrush x:Key="CardBorderBrush" Color="#3A3A3A"/>
            <SolidColorBrush x:Key="SubtleTextForeground" Color="#808080"/>
            <SolidColorBrush x:Key="HelpTextForeground" Color="#A0A0A0"/>
            <SolidColorBrush x:Key="StepBorderBrush" Color="#555555"/>
            <SolidColorBrush x:Key="StepForeground" Color="#888888"/>
            <SolidColorBrush x:Key="UpdateBannerBackground" Color="#2A2210"/>
            <SolidColorBrush x:Key="UpdateBannerBorderBrush" Color="#5C4A00"/>
            <SolidColorBrush x:Key="UpdateBannerForeground" Color="#CCAA40"/>
            <SolidColorBrush x:Key="CardConnectedBorderBrush" Color="#2E7D32"/>
            <SolidColorBrush x:Key="CardConnectedBgBrush" Color="#182E7D32"/>
            <SolidColorBrush x:Key="CardConnectedDotBrush" Color="#43A047"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
