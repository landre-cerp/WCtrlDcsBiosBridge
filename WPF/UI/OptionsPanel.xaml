<UserControl x:Class="WCtrlDcsBiosBridge.UI.OptionsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:WCtrlDcsBiosBridge.UI"
             xmlns:conv="clr-namespace:WCtrlDcsBiosBridge.UI.Converters">

    <UserControl.Resources>
        <conv:AircraftNotActiveConverter x:Key="AircraftNotActive"/>

        <!-- One reusable aircraft options section: renders the header + a
             "Disabled while in use" badge, and auto-disables itself while its own
             aircraft (Header must equal the descriptor DisplayName) is running.
             A new section is just:
                 <HeaderedContentControl Style="{StaticResource AircraftSection}" Header="X">
                     <StackPanel> ...controls... </StackPanel>
                 </HeaderedContentControl> -->
        <Style x:Key="AircraftSection" TargetType="HeaderedContentControl">
            <Setter Property="IsEnabled">
                <Setter.Value>
                    <MultiBinding Converter="{StaticResource AircraftNotActive}">
                        <Binding Path="Header" RelativeSource="{RelativeSource Self}"/>
                        <Binding Path="DetectedAircraftName" RelativeSource="{RelativeSource AncestorType=Window}"/>
                    </MultiBinding>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="HeaderedContentControl">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="{TemplateBinding Header}" FontWeight="SemiBold" FontSize="13"
                                           Foreground="{DynamicResource SubtleTextForeground}"
                                           VerticalAlignment="Center"/>
                                <Border x:Name="DisabledBadge" Margin="8,0,0,0" CornerRadius="4" Padding="6,2"
                                        VerticalAlignment="Center" Visibility="Collapsed"
                                        Background="#1AE65100" BorderBrush="#E65100" BorderThickness="1">
                                    <TextBlock Text="Disabled while in use" FontSize="10" Foreground="#E65100"/>
                                </Border>
                            </StackPanel>
                            <ContentPresenter/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="DisabledBadge" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel>

        <!-- General — always editable -->
        <TextBlock Text="GENERAL" FontWeight="SemiBold" FontSize="11"
                   Foreground="{DynamicResource SubtleTextForeground}" Margin="0,0,0,8"/>

        <CheckBox Content="Disable Lighting Management (for SimApp Pro users)"
                 IsChecked="{Binding DisableLightingManagement, Mode=TwoWay}"
                 Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"
                 Margin="0,4"/>
        <CheckBox Content="Auto-Start Bridge when Ready"
                 IsChecked="{Binding AutoStart, Mode=TwoWay}"
                 Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"
                 Margin="0,4"/>
        <CheckBox Content="Minimize Window on Start"
                 IsChecked="{Binding MinimizeOnStart, Mode=TwoWay}"
                 Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"
                 Margin="0,4"/>

        <Separator Margin="0,12"/>

        <!-- On-close reset — disabled when lighting management is off -->
        <StackPanel IsEnabled="{Binding IsLightingManaged, RelativeSource={RelativeSource AncestorType=Window}}">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="ON CLOSE" FontWeight="SemiBold" FontSize="11"
                           Foreground="{DynamicResource SubtleTextForeground}"
                           VerticalAlignment="Center"/>
                <Border Margin="8,0,0,0" CornerRadius="4" Padding="6,2"
                        VerticalAlignment="Center"
                        Background="#1AE65100" BorderBrush="#E65100" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=StackPanel}}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="Lighting Management disabled" FontSize="10" Foreground="#E65100"/>
                </Border>
            </StackPanel>

            <CheckBox Content="Turn Off Backlights (brightness → 0 %)"
                     IsChecked="{Binding CloseResetBacklight, Mode=TwoWay}"
                     Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"
                     Margin="0,4"/>
            <CheckBox Content="Turn Off Markers (LEDs)"
                     IsChecked="{Binding CloseResetMarkers, Mode=TwoWay}"
                     Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"
                     Margin="0,4"/>
        </StackPanel>

        <Separator Margin="0,12"/>

        <!-- A-10C -->
        <HeaderedContentControl Style="{StaticResource AircraftSection}" Header="A-10C">
            <StackPanel>
                <CheckBox Content="Align CDU Display to Bottom"
                         IsChecked="{Binding A10C.DisplayBottomAligned, Mode=TwoWay}"
                         Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"
                         Margin="0,4"/>
                <CheckBox Content="Display CMS on CDU"
                         IsChecked="{Binding A10C.DisplayCMS, Mode=TwoWay}"
                         Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"
                         Margin="0,4"/>
                <CheckBox Content="Enable Performance Pages"
                         IsChecked="{Binding A10C.EnablePerfPages, Mode=TwoWay}"
                         Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"
                         Margin="0,4"/>
                <StackPanel IsEnabled="{Binding A10C.EnablePerfPages}">
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Perf Page Key:" VerticalAlignment="Center" Width="120"/>
                        <ComboBox ItemsSource="{x:Static ui:OptionsPanel.McduKeyNames}"
                                 SelectedValue="{Binding A10C.PerfPageKey, Mode=TwoWay}"
                                 SelectionChanged="ComboBox_Changed" Width="150"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Next Page Key:" VerticalAlignment="Center" Width="120"/>
                        <ComboBox ItemsSource="{x:Static ui:OptionsPanel.McduKeyNames}"
                                 SelectedValue="{Binding A10C.NextPageKey, Mode=TwoWay}"
                                 SelectionChanged="ComboBox_Changed" Width="150"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Prev Page Key:" VerticalAlignment="Center" Width="120"/>
                        <ComboBox ItemsSource="{x:Static ui:OptionsPanel.McduKeyNames}"
                                 SelectedValue="{Binding A10C.PrevPageKey, Mode=TwoWay}"
                                 SelectionChanged="ComboBox_Changed" Width="150"/>
                    </StackPanel>
                </StackPanel>
                <CheckBox Content="Forward CDU keys to sim (unbind LSK/digits/&quot;/&quot; in DCS)"
                         IsChecked="{Binding A10C.ForwardCduKeysToSim, Mode=TwoWay}"
                         Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"
                         Margin="0,4"/>
            </StackPanel>
        </HeaderedContentControl>

        <Separator Margin="0,12"/>

        <!-- F/A-18C -->
        <HeaderedContentControl Style="{StaticResource AircraftSection}" Header="F/A-18C">
            <StackPanel>
                <TextBlock Text="IFEI page navigation keys"
                          Foreground="{DynamicResource SubtleTextForeground}"
                          FontSize="11" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Show IFEI Key:" VerticalAlignment="Center" Width="120"/>
                    <ComboBox ItemsSource="{x:Static ui:OptionsPanel.McduKeyNames}"
                             SelectedValue="{Binding FA18C.ShowIfeiKey, Mode=TwoWay}"
                             SelectionChanged="ComboBox_Changed" Width="150"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Show UFC Key:" VerticalAlignment="Center" Width="120"/>
                    <ComboBox ItemsSource="{x:Static ui:OptionsPanel.McduKeyNames}"
                             SelectedValue="{Binding FA18C.ShowUfcKey, Mode=TwoWay}"
                             SelectionChanged="ComboBox_Changed" Width="150"/>
                </StackPanel>
            </StackPanel>
        </HeaderedContentControl>

        <Separator Margin="0,12"/>

        <!-- F-14B -->
        <HeaderedContentControl Style="{StaticResource AircraftSection}" Header="F-14B">
            <StackPanel>
                <TextBlock Text="RIO CAP / Radio page keys"
                          Foreground="{DynamicResource SubtleTextForeground}"
                          FontSize="11" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Show RIO Key:" VerticalAlignment="Center" Width="120"/>
                    <ComboBox ItemsSource="{x:Static ui:OptionsPanel.McduKeyNames}"
                             SelectedValue="{Binding F14.RioKey, Mode=TwoWay}"
                             SelectionChanged="ComboBox_Changed" Width="150"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Show Radio Key:" VerticalAlignment="Center" Width="120"/>
                    <ComboBox ItemsSource="{x:Static ui:OptionsPanel.McduKeyNames}"
                             SelectedValue="{Binding F14.RadioKey, Mode=TwoWay}"
                             SelectionChanged="ComboBox_Changed" Width="150"/>
                </StackPanel>
            </StackPanel>
        </HeaderedContentControl>

        <Separator Margin="0,12"/>

        <!-- F-16C -->
        <HeaderedContentControl Style="{StaticResource AircraftSection}" Header="F-16C">
            <StackPanel>
                <TextBlock Text="DED / NAV / RWR page keys"
                          Foreground="{DynamicResource SubtleTextForeground}"
                          FontSize="11" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Show DED Key:" VerticalAlignment="Center" Width="120"/>
                    <ComboBox ItemsSource="{x:Static ui:OptionsPanel.McduKeyNames}"
                             SelectedValue="{Binding F16C.DedKey, Mode=TwoWay}"
                             SelectionChanged="ComboBox_Changed" Width="150"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Show NAV Key:" VerticalAlignment="Center" Width="120"/>
                    <ComboBox ItemsSource="{x:Static ui:OptionsPanel.McduKeyNames}"
                             SelectedValue="{Binding F16C.NavKey, Mode=TwoWay}"
                             SelectionChanged="ComboBox_Changed" Width="150"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Show RWR Key:" VerticalAlignment="Center" Width="120"/>
                    <ComboBox ItemsSource="{x:Static ui:OptionsPanel.McduKeyNames}"
                             SelectedValue="{Binding F16C.RwrKey, Mode=TwoWay}"
                             SelectionChanged="ComboBox_Changed" Width="150"/>
                </StackPanel>
            </StackPanel>
        </HeaderedContentControl>

    </StackPanel>
</UserControl>
